# ─── Supabase ─────────────────────────────────────────────────────────────────

# Project URL — safe to expose (used in browser client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — safe to expose (protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — NEVER expose to the browser
# Used only in server-side API routes to bypass RLS for trusted operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret — used to sign session tokens compatible with Supabase auth
# Found in: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
# NEVER expose to the browser
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── Telegram ─────────────────────────────────────────────────────────────────

# Bot token from @BotFather — NEVER expose to the browser
# Used server-side to validate Telegram initData HMAC signature
TELEGRAM_BOT_TOKEN=your-bot-token

# Bot username without @ — used in the Telegram Login Widget script tag on /dashboard/login
# Example: if your bot is @BirliyKassaBot, set this to BirliyKassaBot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your-bot-username

# ─── App ──────────────────────────────────────────────────────────────────────

# Public app URL — used for CSP headers and redirect URLs
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
